# ── Datadog (for api-demo/run.py and sre_engine.py) ──────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=us5.datadoghq.com

# ── LiteLLM (US1 — LLM Integration) ──────────────────────────────
LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_DEFAULT_MODEL=gpt-4o

# ── OpenAI (for embeddings via lib/embeddings.py) ─────────────────
OPENAI_API_KEY=
OPENAI_BASE_URL=
EMBED_MODEL=text-embedding-3-small

# ── Database (for pgvector / DB-seeding scripts) ─────────────────
DATABASE_URL=postgresql+asyncpg://observai:observai@localhost:5432/observai

# ── Langfuse (US4 — LLM Observability) ────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
