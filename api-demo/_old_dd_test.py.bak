"""
Datadog test tool — Python script puro.

Gera traces, logs, metrics e eventos fake e envia direto pra API Datadog (sem agent).
Usa env vars DATADOG_API_KEY + DATADOG_APP_KEY.

Uso:
  python dd_test.py                    # tudo default (10 iter, 5s)
  python dd_test.py --iter 50 --delay 2 --api-key xxx --app-key yyy
  python dd_test.py --logs-only        # só logs
"""

from __future__ import annotations

import argparse
import json
import os
import random
import sys
import time
import uuid
from datetime import UTC, datetime, timedelta
from typing import Any

import httpx

SERVICES = ["api-gateway", "user-service", "payment-service", "order-service", "notification-service"]
ENVS = ["prod", "staging", "dev"]
STATUSES = ["error", "warn", "info", "debug"]
ENDPOINTS = ["/api/users", "/api/orders", "/api/payments", "/api/notifications", "/health"]
ERROR_MSGS = [
    "Connection timeout after 30s",
    "Database connection pool exhausted",
    "Rate limit exceeded for API key",
    "Invalid authentication token",
    "Memory usage exceeded threshold",
]


def _ts_ms() -> int:
    return int(time.time() * 1000)


def _ts() -> int:
    return int(time.time())


def _tags(service: str, env: str = "prod") -> str:
    return f"service:{service},env:{env},team:observai"


class DdTestClient:
    """Thin httpx wrapper for Datadog API V2 endpoints."""

    def __init__(self, api_key: str, app_key: str, site: str = "datadoghq.com"):
        self.api_base = f"https://api.{site}"
        self.log_intake = f"https://http-intake.logs.{site}"
        self.headers = {"DD-API-KEY": api_key, "Content-Type": "application/json"}
        if app_key:
            self.headers["DD-APPLICATION-KEY"] = app_key
        self._api = httpx.Client(base_url=self.api_base, headers=self.headers, timeout=15)
        self._logs = httpx.Client(base_url=self.log_intake, headers=self.headers, timeout=15)

    def close(self) -> None:
        self._api.close()
        self._logs.close()

    # ── Logs (V2) ──────────────────────────────────────────────

    def send_log(self, message: str, status: str, service: str, env: str = "prod") -> dict[str, Any]:
        """Send a single log entry via Logs API V2."""
        body = [
            {
                "ddsource": "python",
                "ddtags": _tags(service, env),
                "hostname": f"test-{service}",
                "service": service,
                "message": message,
                "status": status,
                "timestamp": _ts_ms(),
            }
        ]
        r = self._logs.post("/api/v2/logs", json=body)
        return {"status": r.status_code}

    # ── Metrics (V2) ──────────────────────────────────────────

    def send_metric(
        self,
        name: str,
        value: float,
        service: str,
        env: str = "prod",
        metric_type: str = "gauge",
    ) -> dict[str, Any]:
        """Send a metric point via Metrics API V2."""
        body = {
            "series": [
                {
                    "metric": name,
                    "type": 1 if metric_type == "count" else 0,  # 0=gauge, 1=count
                    "points": [{"timestamp": _ts(), "value": value}],
                    "tags": [f"service:{service}", f"env:{env}", "team:observai"],
                }
            ]
        }
        r = self._api.post("/api/v2/series", json=body)
        return {"status": r.status_code}

    # ── Events (V1) ───────────────────────────────────────────

    def send_event(
        self,
        title: str,
        text: str,
        alert_type: str = "info",
        service: str = "api-gateway",
        env: str = "prod",
    ) -> dict[str, Any]:
        """Post an event via Events API V1."""
        body = {
            "title": title,
            "text": text,
            "alert_type": alert_type,
            "tags": _tags(service, env),
            "host": f"test-{service}",
            "date_happened": _ts(),
        }
        r = self._api.post("/api/v1/events", json=body)
        return {"status": r.status_code}

    # ── Traces (APM — V0.4, ainda aceita) ───────────────────

    def send_trace(
        self,
        service: str = "api-gateway",
        env: str = "prod",
        error: bool = False,
    ) -> dict[str, Any]:
        """Send a minimal APM trace via Traces API."""
        trace_id = random.getrandbits(64)
        span_id = random.getrandbits(64)
        start_ns = int(time.time_ns())
        dur_ns = random.randint(10_000_000, 500_000_000)  # 10-500ms

        span = {
            "trace_id": trace_id,
            "span_id": span_id,
            "parent_id": None,
            "name": f"{service}.handle_request",
            "resource": random.choice(ENDPOINTS),
            "service": service,
            "type": "web",
            "start": start_ns,
            "duration": dur_ns,
            "error": 1 if error else 0,
            "meta": {
                "env": env,
                "http.method": "GET" if not error else "POST",
                "http.status_code": "500" if error else "200",
                "team": "observai",
            },
            "metrics": {"_sampling_priority_v1": 1},
        }
        body = [[span]]
        r = self._api.put("/api/v0.4/traces", json=body)
        return {"status": r.status_code, "trace_id": trace_id, "span_id": span_id}

    # ── Batch helpers ──────────────────────────────────────────

    def send_batch_logs(self, count: int = 3, service: str = "api-gateway") -> list[dict[str, Any]]:
        results = []
        for _ in range(count):
            msg = random.choice(ERROR_MSGS) if random.random() < 0.3 else f"Request processed OK"
            s = random.choice(STATUSES) if random.random() > 0.7 else "info"
            results.append(self.send_log(msg, s, service))
        return results

    def send_batch_metrics(self, service: str = "api-gateway") -> list[dict[str, Any]]:
        return [
            self.send_metric(f"{service}.request_count", random.randint(10, 500), service, metric_type="count"),
            self.send_metric(f"{service}.latency_ms", round(random.gauss(120, 40), 1), service),
            self.send_metric(f"{service}.error_rate", round(random.uniform(0, 0.05), 4), service),
            self.send_metric(f"{service}.cpu_usage", round(random.uniform(10, 90), 1), service),
        ]

    def send_batch_traces(self, service: str = "api-gateway") -> list[dict[str, Any]]:
        results = []
        for _ in range(3):
            results.append(self.send_trace(service, error=random.random() < 0.1))
        return results


def main() -> None:
    parser = argparse.ArgumentParser(description="Datadog test data generator")
    parser.add_argument("--api-key", default=os.environ.get("DATADOG_API_KEY", ""))
    parser.add_argument("--app-key", default=os.environ.get("DATADOG_APP_KEY", ""))
    parser.add_argument("--site", default=os.environ.get("DATADOG_SITE", "datadoghq.com"))
    parser.add_argument("--iter", type=int, default=10, help="Number of iterations (default: 10)")
    parser.add_argument("--delay", type=float, default=5.0, help="Delay between iterations in seconds (default: 5)")
    parser.add_argument("--logs-only", action="store_true", help="Only send logs")
    parser.add_argument("--metrics-only", action="store_true", help="Only send metrics")
    parser.add_argument("--traces-only", action="store_true", help="Only send traces")
    parser.add_argument("--events-only", action="store_true", help="Only send events")
    args = parser.parse_args()

    if not args.api_key:
        print("❌ DATADOG_API_KEY required (env or --api-key)")
        sys.exit(1)

    client = DdTestClient(args.api_key, args.app_key, args.site)
    print(f"🚀 Datadog test tool — {args.iter} iterations, {args.delay}s delay")
    print(f"   Send to: api.{args.site}")
    print(f"   Mode: ", end="")
    if args.logs_only:
        print("logs only")
    elif args.metrics_only:
        print("metrics only")
    elif args.traces_only:
        print("traces only")
    elif args.events_only:
        print("events only")
    else:
        print("all (logs + metrics + traces + events)")
    print()

    ok = errors = 0
    try:
        for i in range(1, args.iter + 1):
            svc = random.choice(SERVICES)
            env = random.choice(ENVS)
            print(f"[{i}/{args.iter}] service={svc} env={env} — ", end="", flush=True)

            results: list[dict[str, Any]] = []

            if not args.traces_only and not args.metrics_only and not args.events_only:
                results += client.send_batch_logs(random.randint(1, 5), svc)
            if not args.logs_only and not args.traces_only and not args.events_only:
                results += client.send_batch_metrics(svc)
            if not args.logs_only and not args.metrics_only and not args.events_only:
                # Traces skipped — APM intake requires Agent, not HTTP API
                pass
            if not args.logs_only and not args.metrics_only and not args.traces_only:
                # 1 event per iteration
                results.append(
                    client.send_event(
                        f"Test event #{i} — {svc}",
                        f"Iteration {i} for {svc} in {env}",
                        random.choice(["info", "warning", "error"]),
                        svc,
                        env,
                    )
                )

            stats = {r.get("status"): 0 for r in results}
            for r in results:
                stats[r.get("status", 0)] = stats.get(r.get("status", 0), 0) + 1

            parts = [f"{k}={v}" for k, v in sorted(stats.items())]
            print(" ".join(parts))
            ok += sum(v for k, v in stats.items() if str(k).startswith("2"))
            errors += sum(v for k, v in stats.items() if not str(k).startswith("2"))

            if i < args.iter:
                time.sleep(args.delay)

    except KeyboardInterrupt:
        print("\n⏹  Interrupted")
    finally:
        client.close()

    print(f"\n📊 Done — {ok} OK, {errors} errors ({args.iter} iterations)")


if __name__ == "__main__":
    main()
