# Backend environment
DATABASE_URL=postgresql+asyncpg://observai:observai@localhost:5432/observai
REDIS_URL=redis://localhost:6379/0

# Datadog API credentials (set your keys here)
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# App
DEBUG=true
SECRET_KEY=change-me-in-production
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Self-healing
SELF_HEALING_ENABLED=true
SELF_HEALING_APPROVAL_REQUIRED=true

# Auth
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# LLM & AI
LITELLM_API_KEY=
LITELLM_BASE_URL=
LITELLM_DEFAULT_MODEL=gpt-4o
OPENAI_API_KEY=
OPENAI_BASE_URL=
EMBED_MODEL=text-embedding-3-small
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=

INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=<your-strong-password>
